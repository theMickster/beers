# Required for Beers API container startup via docker compose
KeyVault__VaultUri=https://your-keyvault-name.vault.azure.net/
AutoMapperLicenseKey=replace-with-license-key
AZURE_TENANT_ID=replace-with-tenant-id
AZURE_CLIENT_ID=replace-with-client-id
AZURE_CLIENT_SECRET=replace-with-client-secret

# Optional overrides
ASPNETCORE_ENVIRONMENT=Development
API_PORT=8080
BASE_URL=http://localhost:8080
API_IMAGE_NAME=beers-api:quality-gates
API_CONTAINER_NAME=beers-api-quality-gates
TEST_MODE=smoke
VUS=1
DURATION=30s
THRESHOLD_P95=p(95)<1500
THRESHOLD_ERRORS=rate<0.05
