          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response has newsBlogPostId and sets postId variable\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property(\"newsBlogPostId\");",
                  "    pm.collectionVariables.set(\"postId\", jsonData.newsBlogPostId);",
                  "    console.log(\"postId set to: \" + jsonData.newsBlogPostId);",
                  "});",
                  "",
                  "pm.test(\"Response has required fields\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property(\"title\");",
                  "    pm.expect(jsonData).to.have.property(\"brewerId\");",
                  "    pm.expect(String(jsonData.brewerId)).to.not.be.empty;",
                  "});"
                ]
              }
            }
