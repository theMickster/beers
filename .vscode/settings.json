{
  "editor.formatOnSave": true,
  "explorer.autoReveal": true,
  "explorer.compactFolders": false,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[csharp]": {
    "editor.defaultFormatter": "ms-dotnettools.csharp"
  },
  "workbench.iconTheme": "material-icon-theme",
  "material-icon-theme.activeIconPack": "angular",
  "material-icon-theme.hidesExplorerArrows": false,
  "material-icon-theme.folders.associations": {
    "api": "api",
    "src": "src",
    "tests": "test",
    "test": "test",
    "api-read": "test",
    "tools": "tools",
    "dataLoader": "tools",
    "domain": "class",
    "application": "app",
    "common": "shared",
    "controllers": "controller",
    "services": "service",
    "validators": "rules",
    "profiles": "mappings",
    "entities": "class",
    "models": "core",
    "Models": "core",
    ".github": "github",
    ".vscode": "vscode",
    "Properties": "config",
    "Entities": "element",
    "obj": "trash",
    ".vs": "vscode",
    "dataLoader": "database",
    "Services": "molecule"
  },
  "material-icon-theme.files.associations": {
    "copilot-instructions.md": "github",
    ".dockerignore": "docker",
    "Dockerfile": "docker",
    "*.http": "http",
    "*.rest": "http"
  },
  "material-icon-theme.folders.customClones": [
    {
      "name": "teal-core", // Give your custom clone a name
      "base": "core", // The existing icon you want to clone
      "color": "teal-500", // The material palette color you want (e.g., purple-400, purple-500, #A259FF)
      "folderNames": ["Beers.Test.Common", "Beers.Common", "Beers.Domain"] // The folder(s) that should use this new icon
    },
    {
      "name": "orange-application", // Give your custom clone a name
      "base": "container", // The existing icon you want to clone
      "color": "orange-500", // The material palette color you want (e.g., purple-400, purple-500, #A259FF)
      "folderNames": ["Beers.Application"] // The folder(s) that should use this new icon
    },
    {
      "name": "blue-api", // Give your custom clone a name
      "base": "api", // The existing icon you want to clone
      "color": "blue-500", // The material palette color you want (e.g., purple-400, purple-500, #A259FF)
      "folderNames": ["Beers.API"] // The folder(s) that should use this new icon
    },
    {
      "name": "purple-test", // Give your custom clone a name
      "base": "test", // The existing icon you want to clone
      "color": "purple-500", // The material palette color you want (e.g., purple-400, purple-500, #A259FF)
      "folderNames": ["Beers.UnitTests"] // The folder(s) that should use this new icon
    },
    {
      "name": "playwright",
      "base": "test",
      "color": "green",
      "folderNames": ["playwright"]
    },
    {
      "name": "k6",
      "base": "test",
      "color": "red",
      "folderNames": ["k6"]
    }
  ]
}
